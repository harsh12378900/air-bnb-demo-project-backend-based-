<% layout('layouts/biolerplate') -%>
<div class="row row2">
    <div class="col-8 offset-2">
    <h1>Create a new listing</h1>
    <form action="/listing" method="POST" class="needs-validation" novalidate enctype="multipart/form-data">
        <div>
            <label for="title" class="form-lable" >Title</label>
            <input type="text" name="title" placeholder="enter title" class="form-control" required>
            <div class="valid-feedback">
                Title Looks good!
              </div>
        </div>
        <div>
            <label for="description" class="form-lable">Description</label>
            <textarea name="description" placeholder="enter description" rows="3" cols="30" class="form-control" required></textarea>
            <div class="invalid-feedback">
                Please enter the description
              </div>

        </div>
        <!-- <div>
            <label for="image" class="form-lable">image</label>
            <input type="text" name="image" placeholder="enter image URL/Link" class="form-control" >
        </div> -->
        <div>
            <label for="image" class="form-lable">Upload listing image</label>
            <input type="file" name="image" class="form-control" >
        </div>
        <div class="row ">
            <div class="col-md-4">
                <label for="price" class="form-lable">Price</label>
                <input type="text" name="price" placeholder="enter price" type="number" class="form-control" required>
                <div class="invalid-feedback">
                    Please enter the price
                  </div>
            </div>
             
            <div class="col-md-8">
                <label for="country" class="form-lable">Country</label>
                <input type="text" name="country" placeholder="enter country" type="text" class="form-control" required>
                <div class="invalid-feedback">
                    Please enter the country
                  </div>
            </div>
        </div>
        

        <div>
            <label for="location" class="form-lable">Location</label>
            <input type="text" placeholder="enter location" name="location" class="form-control" required>
            <div class="invalid-feedback">
                Please enter the location
              </div>
        </div>
        
        
        <div>
            <button class="btn-1">Add</button>
        </div>
        
    </form>
</div>
</div>
